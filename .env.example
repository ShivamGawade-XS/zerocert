# Supabase Client Settings
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Server-only Service Role (Required for DB admin tasks like updating counters or auth management)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Authentication Config
JWT_SECRET=your_jwt_secret_min_32_characters

# Resend Email Config (Server-side API Key)
RESEND_API_KEY=re_your_api_key

# Upstash Redis Rate Limiting (Server-side Config)
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# Public Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
